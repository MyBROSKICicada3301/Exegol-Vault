# Copy to .env and fill in. These are the app's dedicated PostgreSQL
# role credentials, NOT the 'postgres' superuser from pgAdmin.
# Create the role + database once as superuser:
#   CREATE ROLE "Exegol-Vault" LOGIN PASSWORD '<app_password>';
#   CREATE DATABASE "Exegol-Vault" OWNER "Exegol-Vault";
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Exegol-Vault
DB_APP_USER=Exegol-Vault
DB_APP_PASSWORD=your_app_role_password_here
